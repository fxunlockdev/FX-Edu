{
  "name": "@fxunlock/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, RLS policies, migrations, and validation contracts for FX Academy (Supabase Postgres, EU).",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "files": [
    "src",
    "drizzle.config.ts"
  ],
  "scripts": {
    "lint": "echo \"(db) no lint configured\" && exit 0",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
