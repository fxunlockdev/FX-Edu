{
  "name": "@fxunlock/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared build/lint presets and a Zod-validated env helper for FX Academy.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env.ts",
    "./eslint": "./eslint/base.cjs",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/library.json": "./tsconfig/library.json"
  },
  "files": [
    "src",
    "eslint",
    "tsconfig"
  ],
  "scripts": {
    "lint": "echo \"(config) no lint configured\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
