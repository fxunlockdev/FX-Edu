# Web app env. Copy to .env.local and fill. Supabase keys are publishable
# (client-safe; access is enforced by Row-Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google sign-in: the button renders disabled ("coming soon") until this is
# 'true'. Flip to 'true' only after the Google OAuth provider is configured in
# Supabase (creds added later). Defaults to disabled when unset.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# Deferred (add later):
# Stripe checkout is stubbed until keys are added (server-side, in apps/api)
