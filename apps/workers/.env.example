# @fxunlock/workers — lifecycle messaging worker (M15)
# Copy to .env and fill in. NEVER commit real secrets.

# development | test | production
NODE_ENV=development

# Postgres (Supabase, EU). Feeds the event_outbox consumer.
DATABASE_URL=postgres://user:password@localhost:5432/fxacademy

# Postgres-backed queue runtime (Graphile Worker / pgmq) connection.
# Named REDIS_URL to mirror the API env contract; points at the queue store.
REDIS_URL=redis://localhost:6379

# Resend transactional email.
# Optional in dev/test → the worker falls back to the LogMailer (no real send).
# REQUIRED in production — the worker refuses to start without both.
RESEND_API_KEY=
RESEND_FROM="FX Academy <no-reply@mail.example.com>"

# Optional: override pino log level (default: debug in dev, info in prod)
# LOG_LEVEL=debug
